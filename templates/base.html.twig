<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Product Store{% endblock %}</title>

    <link href="/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="/assets/font-awesome/css/font-awesome.css" rel="stylesheet">
    <link href="/assets/css/plugins/iCheck/custom.css" rel="stylesheet">
    <link href="/assets/css/animate.css" rel="stylesheet">
    <link href="/assets/css/style.css" rel="stylesheet">
</head>
<body>

<div id="wrapper">

    <nav class="navbar-default navbar-static-side" role="navigation">
        <div class="sidebar-collapse">
            <ul class="nav metismenu" id="side-menu">
                <li class="nav-header">
                    <div class="dropdown profile-element">
                        <img alt="image" class="rounded-circle" src="/assets/img/profile_small.jpg">
                        <a data-toggle="dropdown" class="dropdown-toggle" href="#">
                            <span class="block m-t-xs font-bold">Demo User</span>
                            <span class="text-muted text-xs block">Store Panel <b class="caret"></b></span>
                        </a>
                    </div>
                </li>
                <li>
                    <a href="{{ path('product_list') }}">
                        <i class="fa fa-spoon"></i>
                        <span class="nav-label">Products</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('category_list') }}">
                        <i class="fa fa-cubes"></i>
                        <span class="nav-label">Category</span>
                    </a>
                </li>
                <li>
                    <a href="{{ path('cart_view') }}">
                        <i class="fa fa-shopping-cart"></i>
                        <span class="nav-label">Cart</span>
                        <span class="label label-primary pull-right">{{ app.session.get('cart_count', 0) }}</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div id="page-wrapper" class="gray-bg">
        <div class="wrapper wrapper-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'warning' ? 'warning' : 'success' }}" role="alert">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
        {% block body %}{% endblock %}
    </div>
</div>

</body>
</html>
