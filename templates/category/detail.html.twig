{% extends 'base.html.twig' %}
{% block title %}
    Category Details
{% endblock %}
{% block body %}
    <div class="wrapper wrapper-content">
        <h1>{{ category.name }}</h1>
        <p>{{ category.description }}</p>
        <p><strong>ID:</strong> {{ category.id }}</p>
        <a href="{{ path('category_list') }}" class="btn btn-default">Back to list</a>
    </div>
{% endblock %}
