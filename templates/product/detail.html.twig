{% extends 'base.html.twig' %}

{% block title %}
    {{ product.name|default('Product details') }}
{% endblock %}

{% block body %}
    <div class="wrapper wrapper-content">
        <div class="row">
            <div class="col-lg-8">
                <h1>{{ product.name }}</h1>
                <p>{{ product.description }}</p>
                <p><strong>ID:</strong> {{ product.id }}</p>
                <a href="{{ path('cart_add', {'productId': product.id}) }}" class="btn btn-primary">
                    Добавить в корзину
                </a>
            </div>
        </div>

        <div class="row m-t-lg">
            <div class="col-lg-8">
                <h2>Похожие товары</h2>
                <ul>
                    {% for item in similarProducts %}
                        <li>
                            <a href="{{ path('product_detail', {'id': item.id}) }}">{{ item.name }}</a>
                            <div>{{ item.description }}</div>
                        </li>
                    {% else %}
                        <li>Похожие товары не найдены.</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
{% endblock %}
