{% extends 'base.html.twig' %}

{% block title %}
    Product List
{% endblock %}

{% block body %}
    <div class="wrapper wrapper-content">
        <h1>Products</h1>
        <p>Quick demo catalog. Open details or add directly to cart.</p>

        <div class="row">
            {% for product in products %}
                <div class="col-lg-4">
                    <div class="ibox">
                        <div class="ibox-content">
                            <h3>{{ product.name }}</h3>
                            <p>{{ product.description }}</p>
                            <a href="{{ path('product_detail', {'id': product.id}) }}" class="btn btn-xs btn-info">Details</a>
                            <a href="{{ path('cart_add', {'productId': product.id}) }}" class="btn btn-xs btn-primary">Add to cart</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-lg-12">
                    <p>No products found.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
