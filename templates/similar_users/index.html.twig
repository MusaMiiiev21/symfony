{% extends 'base.html.twig' %}

{% block title %}
    Users
{% endblock %}

{% block body %}
    <div class="wrapper wrapper-content">
        <h1>Users</h1>
        <div class="row">
            {% for user in users %}
                <div class="col-lg-4">
                    <div class="ibox">
                        <div class="ibox-content">
                            <h3>{{ user.name }}</h3>
                            <p>Role: {{ user.tag }}</p>
                            <a href="{{ path('user_detail', {'id': user.id}) }}" class="btn btn-xs btn-info">Details</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-lg-12">
                    <p>No users found.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
