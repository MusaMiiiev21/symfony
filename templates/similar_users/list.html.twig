<div class="panel panel-default">
    <div class="panel-heading">
        Similar users
    </div>
    <div class="panel-body">
        <ul class="list-unstyled">
            {% for user in users %}
                <li>
                    <a href="{{ path('user_detail', {'id': user.id}) }}">
                        <strong>#{{ user.id }}</strong> {{ user.name }} ({{ user.tag }})
                    </a>
                </li>
            {% else %}
                <li>No similar users found.</li>
            {% endfor %}
        </ul>
    </div>
</div>
