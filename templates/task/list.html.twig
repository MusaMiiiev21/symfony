``twig {# templates/task/list.html.twig #} <!DOCTYPE html> <html lang="ru"> <head> <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Task Tracker</title> <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css&quot;&gt;
        </head> <body> <div class="containerк mt-5"><h1 class="mb-4">Список задач</h1>

    {# Кнопка для создания новой задачи #}
    &lt;a href=&quot;#&quot; class=&quot;btn btn-primary mb-3&quot;&gt;Создать новую задачу&lt;/a&gt;

    {# Таблица для отображения задач #}
    &lt;table class=&quot;table table-bordered&quot;&gt;
    &lt;thead&gt;
    &lt;tr&gt;
    &lt;th&gt;Задача&lt;/th&gt;
    &lt;th&gt;Статус&lt;/th&gt;
    &lt;th&gt;Срок выполнения&lt;/th&gt;
    &lt;th&gt;Описание&lt;/th&gt;
    &lt;th&gt;Приоритет&lt;/th&gt;
    &lt;th&gt;Действия&lt;/th&gt;
    &lt;/tr&gt;
    &lt;/thead&gt;
    &lt;tbody&gt;
    {# Цикл для отображения задач #}
    {% for task in tasks %}
        &lt;tr&gt;
        &lt;td&gt;{{ task.name }}&lt;/td&gt;
        &lt;td&gt;{{ task.status }}&lt;/td&gt;
        &lt;td&gt;{{ task.dueDate }}&lt;/td&gt;
        &lt;td&gt;{{ task.description }}&lt;/td&gt;
        &lt;td&gt;{{ task.priority }}&lt;/td&gt;
        &lt;td&gt;
        {# Кнопки для редактирования и удаления задачи #}
        &lt;a href=&quot;#&quot; class=&quot;btn btn-warning btn-sm&quot;&gt;Редактировать&lt;/a&gt;
        &lt;a href=&quot;#&quot; class=&quot;btn btn-danger btn-sm&quot;&gt;Удалить&lt;/a&gt;
        &lt;/td&gt;
        &lt;/tr&gt;
    {% endfor %}
    &lt;/tbody&gt;
    &lt;/table&gt;
    </div>

    {# Ссылки на библиотеки JS #} <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js&quot;&gt;&lt;/script&gt;
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js&quot;&gt;&lt;/script&gt;
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js&quot;&gt;&lt;/script&gt; </body> </html> `

