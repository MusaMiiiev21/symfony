{% extends 'base.html.twig' %}

{% block title %}Task Tracker{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Список задач</h1>

        <a href="#" class="btn btn-primary mb-3">Создать новую задачу</a>

        <table class="table table-bordered">
            <thead>
            <tr>
                <th>Задача</th>
                <th>Статус</th>
                <th>Срок выполнения</th>
                <th>Описание</th>
                <th>Приоритет</th>
                <th>Действия</th>
            </tr>
            </thead>
            <tbody>
            {% for task in tasks %}
                <tr>
                    <td>{{ task.name }}</td>
                    <td>{{ task.status }}</td>
                    <td>{{ task.dueDate }}</td>
                    <td>{{ task.description }}</td>
                    <td>{{ task.priority }}</td>
                    <td>
                        <a href="#" class="btn btn-warning btn-sm">Редактировать</a>
                        <a href="#" class="btn btn-danger btn-sm">Удалить</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center">Задач пока нет</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
